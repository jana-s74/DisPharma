{
  "info": {
    "_postman_id": "dispharma-api-collection",
    "name": "DisPharma API",
    "description": "Complete API collection for DisPharma — Inter-Pharmacy Network.\n\nHow to use:\n1. Import this file into Postman\n2. Run '01 Register' or '02 Login' — the JWT token is auto-saved to the {{token}} variable\n3. All protected routes use {{token}} automatically\n4. Replace {{stockId}}, {{transactionId}} with real IDs from responses",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token",   "value": "", "type": "string" },
    { "key": "stockId", "value": "", "type": "string" },
    { "key": "transactionId", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [

        {
          "name": "01 Register",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.token) {",
                "  pm.collectionVariables.set('token', json.token);",
                "  console.log('✅ Token saved:', json.token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"medicalName\": \"Test Medical Store\",\n  \"ownerName\": \"Ravi Kumar\",\n  \"phone\": \"9876543210\",\n  \"licenseNo\": \"DL-TN-123456\",\n  \"address\": \"12, Anna Salai, Chennai\",\n  \"pincode\": \"600001\",\n  \"password\": \"test1234\",\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [80.2707, 13.0827]\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          },
          "response": []
        },

        {
          "name": "02 Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.token) {",
                "  pm.collectionVariables.set('token', json.token);",
                "  console.log('✅ Token saved:', json.token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"password\": \"test1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "response": []
        },

        {
          "name": "03 Get Me (profile)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          },
          "response": []
        }

      ]
    },

    {
      "name": "📦 Stock",
      "item": [

        {
          "name": "04 Get My Stock",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/stock/my", "host": ["{{baseUrl}}"], "path": ["stock", "my"] }
          },
          "response": []
        },

        {
          "name": "05 Add Medicine to Stock",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json._id) {",
                "  pm.collectionVariables.set('stockId', json._id);",
                "  console.log('✅ Stock ID saved:', json._id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"medicineId\": \"000000000000000000000000\",\n  \"medicineName\": \"Dolo 650\",\n  \"quantity\": 50,\n  \"buyPrice\": 30,\n  \"sellPrice\": 35\n}"
            },
            "url": { "raw": "{{baseUrl}}/stock/add", "host": ["{{baseUrl}}"], "path": ["stock", "add"] }
          },
          "response": []
        },

        {
          "name": "06 Get Low Stock (qty ≤ 10)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/stock/low", "host": ["{{baseUrl}}"], "path": ["stock", "low"] }
          },
          "response": []
        },

        {
          "name": "07 Update Stock Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 8,\n  \"buyPrice\": 28,\n  \"sellPrice\": 33\n}"
            },
            "url": { "raw": "{{baseUrl}}/stock/{{stockId}}", "host": ["{{baseUrl}}"], "path": ["stock", "{{stockId}}"] }
          },
          "response": []
        },

        {
          "name": "08 Delete Stock Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/stock/{{stockId}}", "host": ["{{baseUrl}}"], "path": ["stock", "{{stockId}}"] }
          },
          "response": []
        }

      ]
    },

    {
      "name": "🔍 Search",
      "item": [

        {
          "name": "09 Search Medicine by Name",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/search?name=Dolo",
              "host": ["{{baseUrl}}"],
              "path": ["search"],
              "query": [{ "key": "name", "value": "Dolo" }]
            }
          },
          "response": []
        },

        {
          "name": "10 Explore Nearby (all medicines)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/search/explore", "host": ["{{baseUrl}}"], "path": ["search", "explore"] }
          },
          "response": []
        }

      ]
    },

    {
      "name": "🧾 Bill",
      "item": [

        {
          "name": "11 Generate Bill (4% margin)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.transaction && json.transaction._id) {",
                "  pm.collectionVariables.set('transactionId', json.transaction._id);",
                "  console.log('✅ Transaction ID saved:', json.transaction._id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"toMedicalId\": \"PASTE_TARGET_MEDICAL_ID_HERE\",\n  \"items\": [\n    {\n      \"medicineId\": \"000000000000000000000000\",\n      \"medicineName\": \"Dolo 650\",\n      \"quantity\": 5,\n      \"buyPrice\": 30\n    },\n    {\n      \"medicineId\": \"000000000000000000000000\",\n      \"medicineName\": \"Pan D\",\n      \"quantity\": 2,\n      \"buyPrice\": 45\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/bill/generate", "host": ["{{baseUrl}}"], "path": ["bill", "generate"] }
          },
          "response": []
        },

        {
          "name": "12 Get Bill History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bill/history", "host": ["{{baseUrl}}"], "path": ["bill", "history"] }
          },
          "response": []
        },

        {
          "name": "13 Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bill/stats", "host": ["{{baseUrl}}"], "path": ["bill", "stats"] }
          },
          "response": []
        },

        {
          "name": "14 Download Bill PDF",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bill/pdf/{{transactionId}}", "host": ["{{baseUrl}}"], "path": ["bill", "pdf", "{{transactionId}}"] }
          },
          "response": []
        }

      ]
    },

    {
      "name": "✅ Health Check",
      "item": [
        {
          "name": "00 API Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "response": []
        }
      ]
    }

  ]
}
